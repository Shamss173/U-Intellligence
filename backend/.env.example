# Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./u_intelligence.db

# RAG Configuration
RAG_ENABLED=True
RAG_MODEL_PROVIDER=google
RAG_EMBEDDING_MODEL=models/gemini-embedding-001
RAG_VECTOR_DB=chroma
RAG_VECTOR_DB_PATH=./my_vector_db_v2
RAG_LLM_MODEL=gemini-2.5-flash
RAG_LLM_TEMPERATURE=0.7
RAG_LLM_MAX_TOKENS=1000
RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
